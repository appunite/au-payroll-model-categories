# Invoice Classifier Configuration
# Copy this file to .env and fill in your values

# Model Configuration
MODEL_VERSION=1.0.0

# API Configuration
API_HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# Authentication & Rate Limiting
API_TOKEN=              # Required: Bearer token for /predict/* endpoints (app won't start without it)
RATE_LIMIT_RPM=60       # Max requests per minute per IP for prediction endpoints

# Logging Configuration
LOG_REQUESTS=true       # Log full request input data
LOG_RESPONSES=true      # Log full response output data
LOG_PERFORMANCE=true    # Log request processing time/latency
LOG_FORMAT=text         # Logging format: "text" (human-readable) or "json" (structured)

# Database Configuration (Required for fetching training data)
# Option 1: Use full connection URL
DATABASE_URL=postgresql://user:password@host:5432/database

# Option 2: Or use individual components (if DATABASE_URL not set)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=your_database
# DB_USER=your_username
# DB_PASSWORD=your_password
