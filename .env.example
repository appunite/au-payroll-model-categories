# Invoice Classifier Configuration
# Copy this file to .env and fill in your values

# Model Configuration
MODEL_VERSION=1.0.0

# API Configuration
API_HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# Database Configuration (Optional - for fetching training data)
# Uncomment and fill in if you want to fetch training data directly from database
# DATABASE_URL=postgresql://user:password@host:5432/database
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=your_database
# DB_USER=your_username
# DB_PASSWORD=your_password
