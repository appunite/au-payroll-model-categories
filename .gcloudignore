data/*.csv
data/*.json

# Development files
.vscode/
.idea/
*.md
tests/
.env
.env.local
.env.example

# Build artifacts
dist/
build/
*.egg-info/

# OS
.DS_Store
Thumbs.db

# Examples (not needed in production)
examples/

# DO NOT IGNORE: Models are required for inference
# models/ directory and *.joblib files MUST be included
